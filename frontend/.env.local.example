# WebSocket URL of the FastAPI backend
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/transcribe

# ── LLM provider ─────────────────────────────────────────────────────────────
# Leave ANTHROPIC_API_KEY unset to use the local Ollama model (qwen2.5:7b).
# Set it to a key from https://console.anthropic.com to use Claude instead —
# much stronger answers for the copilot, tribe search, and NL updates.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# On-chain org directory (org.move module — upgraded customer_memory package)
SUI_ORG_PACKAGE_ID=0x...

# LLM via OpenRouter (OpenAI-compatible gateway) — set this to use hosted AI
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=~anthropic/claude-sonnet-latest
