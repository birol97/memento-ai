# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CORS — comma-separated origins for the browser client
ALLOWED_ORIGINS=http://localhost:3000
# Regex of additional allowed origins. Defaults to any *.vercel.app so rotating
# Vercel deploy/preview URLs don't break the browser with a CORS "Failed to fetch".
# Set empty to disable, or override for a custom domain.
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Whisper
# Model size: tiny.en, base.en, small.en, medium.en, large-v3
# tiny.en / base.en run comfortably on CPU; small.en+ benefits from GPU.
WHISPER_MODEL=base.en
# Device: cpu | cuda | auto
WHISPER_DEVICE=cpu
# Compute type: int8 (CPU), float16 (GPU), int8_float16 (GPU low-mem)
WHISPER_COMPUTE_TYPE=int8

# Audio pipeline
SAMPLE_RATE=16000
# Max seconds of audio to keep in the rolling buffer before forcing a commit
# (safety net — the normal commit path is VAD-driven, see below).
MAX_BUFFER_SECONDS=15
# Run inference once we've accumulated this many new seconds since the last run
INFERENCE_INTERVAL_SECONDS=1.0

# Voice-activity-driven turn detection (M3)
# When enabled, the server commits a final transcript on detected silence
# rather than when the rolling buffer fills.
VAD_ENABLED=true
# Speech-onset threshold. Probabilities >= this are treated as speech.
VAD_THRESHOLD=0.5
# Hysteresis: must drop below this before silence counting starts.
VAD_NEG_THRESHOLD=0.35
# Minimum contiguous speech (ms) before a speech_start fires.
VAD_MIN_SPEECH_MS=200
# Minimum contiguous silence (ms) inside a turn before turn_end fires.
VAD_MIN_SILENCE_MS=600

# Persistence (M4)
# SQLite file path. Created on first boot. WAL mode is enabled automatically.
DB_PATH=data/copilot.sqlite3

# Streaming copilot (M4) — live mic advisor + call summaries.
# Provider is auto-selected: if OPENROUTER_API_KEY is set, suggestions stream
# from OpenRouter (hosted — required for a hosted backend with no local model);
# otherwise it falls back to the local Ollama server below.
SUGGESTIONS_ENABLED=true
SUGGESTION_HISTORY_SUMMARIES=5
SUGGESTION_MAX_TOKENS=220
# --- Hosted provider (recommended for deploy) ---
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=google/gemini-2.5-flash   # cheap+fast; good for live coaching
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# --- Local fallback (used only when OPENROUTER_API_KEY is empty) ---
# Pull the model first, e.g. `ollama pull qwen2.5:7b`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_REQUEST_TIMEOUT=120

# ── Walrus-backed long-term customer memory (the hackathon angle) ──
# Recall prior-call memory into the copilot prompt on call start; a post-call
# summarizer extracts typed entries (fact/preference/commitment/signal/history)
# and writes them back to Walrus. Raw Walrus over the public testnet HTTP
# publisher/aggregator — no MemWal relayer, no wallet/funds needed for testnet.
MEMORY_ENABLED=true
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# Storage lifetime in Walrus epochs.
WALRUS_EPOCHS=5
WALRUS_TIMEOUT=60
# How many recency-ranked entries of each volatile type to surface on recall.
MEMORY_RECALL_SIGNALS=5
MEMORY_RECALL_HISTORY=8

# ── On-chain recovery (Walrus-first memory) ──
# The customer-memory path treats Walrus as the source of truth and SQLite as a
# disposable cache. When a customer isn't cached, the backend resolves its
# on-chain CustomerMemoryCap → anchored Walrus manifest → rebuilds the cache.
# These settings let the backend READ the chain (it never signs). Leave
# SUI_PACKAGE_ID / SUI_SERVER_ADDRESS empty to disable recovery.
SUI_NETWORK=testnet
# SUI_RPC_URL=                       # blank → derived from SUI_NETWORK
# SUI_PACKAGE_ID=0x...               # same published package the frontend uses
# SUI_SERVER_ADDRESS=0x...           # address that OWNS the caps (frontend signer's address)
# Rebuild the whole client list from owned caps on startup (usable on empty DB).
REBUILD_FROM_CHAIN_ON_STARTUP=true

# ── Auth / multi-tenancy (Phase 1) ──
# HS256 secret shared with the Next frontend (which mints the session JWT after
# verifying the user's zkLogin/Enoki session). MUST match the frontend value.
SESSION_JWT_SECRET=
# While false, anonymous requests resolve to a default-org owner so the existing
# UI keeps working. Flip true to reject unauthenticated calls (Phase 6).
AUTH_REQUIRED=false
# Name of the tenant that existing single-tenant data is backfilled into.
DEFAULT_ORG_NAME=Default Org

# ── Voice Relay (shared call infra; not a user-facing channel) ──
# One relay instance serves all users; each call uses that user's own Twilio
# creds (sent per-call). Point at the running voice-relay app.
VOICE_RELAY_URL=
VOICE_RELAY_API_KEY=

# Encrypts connected channel credentials (SMTP/Twilio) at rest.
CHANNELS_ENC_SECRET=
